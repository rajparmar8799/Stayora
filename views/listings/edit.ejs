<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your Listing</title>
</head>
<body>
        <h1>Edit Your Listing : </h1>
        <br>
        <br>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" >
            Title : <input name="listing[title]" value="<%= listing.title %>" type="text">
            <br>
            <textarea rows="11" cols="60" name="listing[description]"><%= listing.description %></textarea>
            <br>
            URL : <input name="listing[image]" value="<%= listing.image %>" type="text">
            <br>
            Price : <input name="listing[price]" value="<%= listing.price %>" type="text">
            <br>
            Location : <input name="listing[location]" value="<%= listing.location %>" type="text">
            <br>
            Coutntry : <input name="listing[country]" value="<%= listing.country %>" type="text">
            <br>
            <button type="submit">Edit</button>
        </form>
</body>
</html>