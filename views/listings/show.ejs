<% layout("layouts/boilerplate") %>

    <div class="row">
        <div class="col-md-8">

            <div class="show-image-wrapper">
                <img src="<%= askedListing.image %>" class="show-image">
            </div>

            <h2 class="mt-4">
                <%= askedListing.title %>
            </h2>

            <h5 class="text-accent">
                ₹ <%= askedListing.price.toLocaleString("en-IN") %> • <%= askedListing.location %>, <%= askedListing.country %>
            </h5>

            <p class="mt-3">
                <%= askedListing.description %>
            </p>

            <div class="mt-4">
                <a href="/listings/<%= askedListing._id %>/edit" class="btn btn-warning btn-sm">Edit</a>

                <form method="POST" action="/listings/<%= askedListing._id %>?_method=DELETE" class="d-inline">
                    <button class="btn btn-danger btn-sm">Delete</button>
                </form>
            </div>

        </div>
    </div>