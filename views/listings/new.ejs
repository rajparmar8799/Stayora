<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create new Listing</title>
</head>
<body>
    <h1>Create New Listing : </h1>
    <br>
    <br>
    <form method="POST" action="/listings">
        Title : <input name="listing[title]" placeholder="Enter the title of your listing" type="text"><br>
       <textarea rows="11" cols="60" name="listing[description]" placeholder="Enter the description of your listing"></textarea><br>
       URL : <input name="listing[image]" placeholder="Enter the URL/LINK of YOUR PROPERTY IMAGE" type="text"><br>
        Price : <input name="listing[price]" placeholder="Enter the Price of your listing" type="text"><br>
        Location : <input name="listing[location]" placeholder="Enter the location of your listing" type="text"><br>
        Coutntry : <input name="listing[country]" placeholder="which country your property is located in ?" type="text"><br>
        <button type="submit">Add</button>
    </form>
</body>
</html>