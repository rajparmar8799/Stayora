<% layout('layouts/boilerplate') %>

    <div class="container-fluid p-0">
        <div class="row g-0 align-items-center bg-dark text-white hero-section shadow-lg">
            <div class="col-lg-6 p-5 animate-fade-in">
                <h1 class="display-2 fw-bold mb-4">Find Your Next <span class="text-teal">Escape</span>.</h1>
                <p class="lead mb-5 opacity-75">From cozy beachfront cottages to modern lofts, discover the perfect stay
                    for your next journey.</p>

                <a href="/listings" class="btn btn-teal btn-lg px-5 py-3 rounded-pill shadow">
                    Explore All Listings <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>

            <div class="col-lg-6 d-none d-lg-block">
                <img src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?auto=format&fit=crop&w=1200&q=80"
                    class="img-fluid vh-100 object-fit-cover animate-slide-left" alt="Beachfront Villa">
            </div>
        </div>
    </div>

    <div class="container my-5 py-5 text-center">
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="p-4 border-0 card h-100 shadow-sm hover-up">
                    <i class="bi bi-shield-check display-5 text-teal mb-3"></i>
                    <h4>Verified Stays</h4>
                    <p class="text-muted">Hand-picked homes with verified reviews.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="p-4 border-0 card h-100 shadow-sm hover-up">
                    <i class="bi bi-wallet2 display-5 text-teal mb-3"></i>
                    <h4>Best Prices</h4>
                    <p class="text-muted">No hidden fees, just great value for your trip.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="p-4 border-0 card h-100 shadow-sm hover-up">
                    <i class="bi bi-headset display-5 text-teal mb-3"></i>
                    <h4>24/7 Support</h4>
                    <p class="text-muted">We're here to help you, anytime, anywhere.</p>
                </div>
            </div>
        </div>
    </div>